{
  "$schema": "https://opencode.ai/config.json",
  "agent": {
    "ask": {
      "mode": "primary",
      "tools": {
        "*": false
      },
      "prompt": ""
    }
  },
  "mcp": {
    "chrome-devtools": {
      "type": "local",
      "command": ["npx", "-y", "chrome-devtools-mcp@latest", "--executablePath", "/usr/bin/chromium"],
      "enabled": true
    }
  }
}
